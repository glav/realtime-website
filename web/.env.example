# Frontend Configuration (web/.env.local)
# Copy this file to web/.env.local for frontend-specific variables.
#
# NOTE: The backend requires a separate .env in the repository root with:
#   AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
#   AZURE_OPENAI_DEPLOYMENT=your-deployment-name
# See docs/azure-ad-setup.md for full setup instructions.

# Backend URL (optional - leave empty to use the Vite proxy for local development)
# Set this in production to point to your deployed backend, e.g.:
# VITE_BACKEND_URL=https://your-backend.azurewebsites.net
VITE_BACKEND_URL=
